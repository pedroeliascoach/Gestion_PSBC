generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  PROMOTOR
  INSTRUCTOR
}

enum EstatusCapacitacion {
  PLANEADA
  EN_PROGRESO
  COMPLETADA
  CANCELADA
}

enum EstatusProyecto {
  PLANEADO
  EN_EJECUCION
  COMPLETADO
  CANCELADO
}

enum TipoReporte {
  VISITA
  CAPACITACION
  PROYECTO
  GENERAL
}

enum EstatusPago {
  PENDIENTE
  EN_PROCESO
  PAGADO
}

enum TipoEntregable {
  REPORTE_FINAL
  FACTURA
}

model Usuario {
  id         String   @id @default(uuid())
  nombre     String
  email      String   @unique
  password   String
  rol        Rol
  activo     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  promotor   Promotor?
  instructor Instructor?
}

model Promotor {
  id         String   @id @default(uuid())
  usuarioId  String   @unique
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  comunidades ComunidadPromotor[]
  visitas     Visita[]
  eventos     Evento[]
}

model Instructor {
  id         String   @id @default(uuid())
  usuarioId  String   @unique
  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())

  capacitaciones CapacitacionInstructor[]
  proveedor      Proveedor?
}

model Comunidad {
  id           String    @id @default(uuid())
  nombre       String
  municipio    String
  estado       String    @default("Tamaulipas")
  etapaActual  Int       @default(1)
  fechaIngreso DateTime
  fechaEgreso  DateTime?
  activa       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  promotores     ComunidadPromotor[]
  capacitaciones Capacitacion[]
  proyectos      Proyecto[]
  visitas        Visita[]
  presupuestos   Presupuesto[]
  reportes       Reporte[]
  eventos        Evento[]
  historicoEtapas HistoricoEtapa[]
}

model ComunidadPromotor {
  id          String   @id @default(uuid())
  comunidadId String
  promotorId  String
  asignadoEn  DateTime @default(now())
  activo      Boolean  @default(true)

  comunidad Comunidad @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  promotor  Promotor  @relation(fields: [promotorId], references: [id], onDelete: Cascade)

  @@unique([comunidadId, promotorId])
}

model HistoricoEtapa {
  id          String    @id @default(uuid())
  comunidadId String
  etapa       Int
  fechaInicio DateTime
  fechaFin    DateTime?

  comunidad Comunidad @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
}

model Capacitacion {
  id          String              @id @default(uuid())
  titulo      String
  descripcion String?
  comunidadId String
  fechaInicio DateTime?
  fechaFin    DateTime?
  estatus     EstatusCapacitacion @default(PLANEADA)
  proveedorId String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  comunidad    Comunidad               @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  proveedor    Proveedor?              @relation(fields: [proveedorId], references: [id])
  instructores CapacitacionInstructor[]
  reportes     Reporte[]
  fotografias  Fotografia[]
}

model CapacitacionInstructor {
  id             String @id @default(uuid())
  capacitacionId String
  instructorId   String

  capacitacion Capacitacion @relation(fields: [capacitacionId], references: [id], onDelete: Cascade)
  instructor   Instructor   @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([capacitacionId, instructorId])
}

model Proyecto {
  id          String          @id @default(uuid())
  nombre      String
  descripcion String?
  comunidadId String
  fechaInicio DateTime?
  fechaFin    DateTime?
  estatus     EstatusProyecto @default(PLANEADO)
  presupuesto Decimal?        @db.Decimal(12, 2)
  proveedorId String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  comunidad   Comunidad  @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  proveedor   Proveedor? @relation(fields: [proveedorId], references: [id])
  reportes    Reporte[]
  fotografias Fotografia[]
}

model Visita {
  id            String   @id @default(uuid())
  comunidadId   String
  promotorId    String
  fecha         DateTime
  descripcion   String?
  observaciones String?
  createdAt     DateTime @default(now())

  comunidad   Comunidad  @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  promotor    Promotor   @relation(fields: [promotorId], references: [id], onDelete: Cascade)
  reportes    Reporte[]
  fotografias Fotografia[]
}

model Evento {
  id          String   @id @default(uuid())
  comunidadId String
  promotorId  String
  titulo      String
  descripcion String?
  fecha       DateTime
  createdAt   DateTime @default(now())

  comunidad Comunidad @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  promotor  Promotor  @relation(fields: [promotorId], references: [id], onDelete: Cascade)
}

model Reporte {
  id             String      @id @default(uuid())
  titulo         String
  contenido      String
  tipo           TipoReporte
  autorUsuarioId String
  comunidadId    String?
  capacitacionId String?
  proyectoId     String?
  visitaId       String?
  porcentajeAvance Int?
  temasImpartidos  String?
  asistentes       Int?
  createdAt      DateTime    @default(now())

  comunidad    Comunidad?    @relation(fields: [comunidadId], references: [id])
  capacitacion Capacitacion? @relation(fields: [capacitacionId], references: [id])
  proyecto     Proyecto?     @relation(fields: [proyectoId], references: [id])
  visita       Visita?       @relation(fields: [visitaId], references: [id])
  fotografias  Fotografia[]
}

model Fotografia {
  id             String   @id @default(uuid())
  rutaArchivo    String
  nombreOriginal String
  descripcion    String?
  fecha          DateTime @default(now())
  visitaId       String?
  capacitacionId String?
  proyectoId     String?
  reporteId      String?

  visita       Visita?       @relation(fields: [visitaId], references: [id])
  capacitacion Capacitacion? @relation(fields: [capacitacionId], references: [id])
  proyecto     Proyecto?     @relation(fields: [proyectoId], references: [id])
  reporte      Reporte?      @relation(fields: [reporteId], references: [id])
}

model Presupuesto {
  id          String   @id @default(uuid())
  comunidadId String
  anio        Int
  monto       Decimal  @db.Decimal(12, 2)
  descripcion String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comunidad Comunidad @relation(fields: [comunidadId], references: [id], onDelete: Cascade)
  gastos    Gasto[]

  @@unique([comunidadId, anio])
}

model Gasto {
  id            String   @id @default(uuid())
  presupuestoId String
  concepto      String
  monto         Decimal  @db.Decimal(12, 2)
  fecha         DateTime
  proveedorId   String?
  createdAt     DateTime @default(now())

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  proveedor   Proveedor?  @relation(fields: [proveedorId], references: [id])
}

model Proveedor {
  id          String  @id @default(uuid())
  nombre      String
  rfc         String  @unique
  contacto    String?
  telefono    String?
  email       String?
  activo      Boolean @default(true)
  instructorId String? @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  instructor     Instructor?          @relation(fields: [instructorId], references: [id])
  requisitos     ProveedorRequisito[]
  capacitaciones Capacitacion[]
  proyectos      Proyecto[]
  gastos         Gasto[]
  entregables    ProveedorEntregable[]
}

model RequisitoCatalogo {
  id          String  @id @default(uuid())
  nombre      String
  descripcion String?
  obligatorio Boolean @default(true)
  orden       Int     @default(0)
  activo      Boolean @default(true)
  createdAt   DateTime @default(now())

  proveedorRequisitos ProveedorRequisito[]
}

model ProveedorRequisito {
  id            String    @id @default(uuid())
  proveedorId   String
  requisitoId   String
  cumplido      Boolean   @default(false)
  fechaCumplido DateTime?
  observaciones String?
  documento     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  proveedor Proveedor         @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  requisito RequisitoCatalogo @relation(fields: [requisitoId], references: [id], onDelete: Cascade)

  @@unique([proveedorId, requisitoId])
}

model ProveedorEntregable {
  id            String         @id @default(uuid())
  proveedorId   String
  tipo          TipoEntregable
  entregado     Boolean        @default(false)
  fechaEntrega  DateTime?
  rutaArchivo   String?
  nombreArchivo String?
  estatusPago   EstatusPago    @default(PENDIENTE)
  observaciones String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  proveedor Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@unique([proveedorId, tipo])
}
